{
  "name": "happyeverything",
  "private": true,
  "workspaces": [
    "frontend",
    "server"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter server dev",
    "dev:server": "pnpm --filter server dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "pnpm --filter server build && pnpm --filter frontend build",
    "build:server": "pnpm --filter server build",
    "build:frontend": "pnpm --filter frontend build",
    "start": "pnpm --filter server start",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:server": "pnpm --filter server lint",
    "lint:frontend": "pnpm --filter frontend lint",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.2",
    "@hono/zod-validator": "^0.7.0",
    "@sindresorhus/slugify": "^2.2.1",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.8",
    "@tanstack/zod-adapter": "^1.121.2",
    "dev": "^0.1.3",
    "dotenv": "^16.5.0",
    "dotenv-cli": "^10.0.0",
    "hono": "^4.9.7",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "@types/node": "^20.11.17",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  },
  "lint-staged": {
    "server/**/*.{js,ts}": ["pnpm lint:server"],
    "frontend/**/*.{js,ts,tsx}": ["pnpm lint:frontend"]
  }
}
